# AI Fitness Coach Configuration
# Copy this file to ../.env and adjust as needed.

# Path to the SQLite database (default: data/kai_health.db)
# KAI_DB_PATH=./data/kai_health.db

# Path to your profile JSON (default: config/profile.json)
# KAI_PROFILE_PATH=./config/profile.json

# Path to the exercise database (default: src/exercises.md)
# KAI_EXERCISES_PATH=./src/exercises.md

# Your timezone (used for cron job reminders)
# KAI_TIMEZONE=America/New_York

# WhatsApp group chat ID (for automated reminders)
# KAI_WHATSAPP_CHAT_ID=your-group-id@g.us
